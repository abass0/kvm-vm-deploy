#cloud-config
# {{ ansible_managed }}

hostname: {{ vm_hostname }}
fqdn: {{ vm_hostname }}.{{ vm_domain }}
prefer_fqdn_over_hostname: true

users:
  - name: {{ vm_user }}
    groups: wheel
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - {{ vm_ssh_public_key }}

ssh_pwauth: false
disable_root: true

# Set timezone
timezone: UTC

# Grow root filesystem
growpart:
  mode: auto
  devices: ['/']

# Do not run package updates or install packages
package_update: false
package_upgrade: false

# Final message
final_message: "Cloud-init provisioning complete for {{ vm_hostname }}"
